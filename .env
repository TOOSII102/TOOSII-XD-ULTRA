# ╔══════════════════════════════════════╗
# ║     TOOSII XD ULTRA v2.0.0          ║
# ║     Environment Configuration        ║
# ╚══════════════════════════════════════╝

# ── Session ID ─────────────────────────────────────────────────────────────
# HOW TO GET IT:
# 1. Run your session generator (cd toosii_session && npm start)
# 2. Open http://localhost:5000 in your browser
# 3. Enter your WhatsApp number → link device → scan QR or enter pair code
# 4. Check your WhatsApp DM — you will receive a long message starting with TOOSII~
# 5. Copy that entire message and paste it below after the = sign
# ⚠️  Do NOT add spaces, quotes or line breaks
# Example: SESSION_ID=TOOSII~eyJub2lzZUtleS...
SESSION_ID=PASTE_YOUR_TOOSII~_SESSION_HERE

# ── Bot Name ────────────────────────────────────────────────────────────────
# The name your bot will show in menus and messages
# Example: BOT_NAME=TOOSII XD ULTRA
BOT_NAME=TOOSII XD ULTRA

# ── Command Prefix ──────────────────────────────────────────────────────────
# The symbol people type before commands
# Example: . means commands are .ping .menu .help etc
# Common choices: .  !  /  #
BOT_PREFIX=.

# ── Owner Number ────────────────────────────────────────────────────────────
# YOUR WhatsApp number with country code
# ⚠️  No + sign, no spaces, no dashes
# Example: Kenya 0748340864 → 254748340864
#          Nigeria 08012345678 → 2348012345678
#          USA +13125550123 → 13125550123
OWNER_NUMBER=YOUR_NUMBER_WITH_COUNTRY_CODE

# ── Port ────────────────────────────────────────────────────────────────────
# Port for hosting platforms like Heroku, Railway, Render
# Leave as 3000 unless your host requires a different port
PORT=3000
